{
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "frontend/src/**/*.{js,jsx}": [
      "npx --prefix frontend eslint --config frontend/eslint.config.js --fix",
      "npx --prefix frontend prettier --write"
    ],
    "frontend/src/**/*.css": [
      "npx --prefix frontend prettier --write"
    ]
  }
}
