# External invoice parsing service
# Required — application will not start without these
INVOICE_PARSER_URL=https://your-invoice-parser-service.example.com
INVOICE_PARSER_API_KEY=your-api-key-here

# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/labelmanager
DATABASE_USERNAME=dev
DATABASE_PASSWORD=dev

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=costs
S3_REGION=us-east-1
S3_ACCESS_KEY=dev
S3_SECRET_KEY=devdevdev
